---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const parts1 = [
  { n: "Kısım I", t: "Yeni Dijital Çalışanınızla Tanışın", d: "Ajan nedir, ne değildir; sorumluluk neden devredilemez; beş ilke." },
  { n: "Kısım II", t: "Ajanları Sorumlu Kurmak", d: "Envanter, görev tanımı, kimlik ve erişim, insan onayı, acil durdurma." },
  { n: "Kısım III", t: "Güvenli ve Şeffaf Tutmak", d: "Veri erişimi, kayıt düzeni, aydınlatma, saldırılar, izleme." },
  { n: "Kısım IV", t: "KVKK Uyumu: Kitabın Kalbi", d: "İşleme şartları, Kurum rehberleri, yurt dışı aktarım, VERBİS, veri ihlali." },
  { n: "Kısım V", t: "Onlar Listesi", d: "On altın kural, on yaygın hata ve teknik ekibe on korkuluk." },
  { n: "Ekler", t: "Sözlük & Şablonlar", d: "Doldurulabilir envanter, görev tanımı, aydınlatma ve olay planı şablonları." },
];
const temalar = [
  { l: "Onay & korkuluk", n: 4 }, { l: "Acil durdurma", n: 3 }, { l: "Otomatik karar", n: 3 },
  { l: "Hesap verebilirlik", n: 3 }, { l: "İzleme & drift", n: 4 }, { l: "Fiziksel güvenlik", n: 1 },
  { l: "Otonomi & hız", n: 2 }, { l: "Tedarik zinciri", n: 4 }, { l: "Açık rıza", n: 1 },
  { l: "İstem enjeksiyonu", n: 5 }, { l: "Kötüye kullanım", n: 1 }, { l: "Kimlik & yetki", n: 2 },
];
---
<Base title="Ücretsiz E-Kitaplar — Ajan Hukuku ve Yönetişimi | Agent Hukuku" description="Yapay zeka ajanlarının hukuku ve yönetişimi üzerine ücretsiz e-kitaplar: 'Yapay Zeka Ajanları & KVKK' uygulama rehberi ve 'Agent Vakaları 2026' gerçek olay derlemesi.">
<Header />
<main>
<section class="page-hero"><div class="wrap">
  <div class="breadcrumb"><a href="/">Ana sayfa</a> · Kitaplar</div>
  <span class="kicker">Kitaplar</span>
  <h1>Ücretsiz e-kitaplar</h1>
  <p class="lead">İki kitap, tek çerçeve. Biri ajan yönetişimini envanterden olay müdahalesine uçtan uca kuruyor; diğeri bu ilkelerin gerçek dünyada eksik kaldığında ne olduğunu 33 olayla gösteriyor. İkisi de ücretsiz, Türkçe ve vaka temelli.</p>
</div></section>

<!-- KİTAP 1 -->
<section class="kl-book"><div class="wrap"><div class="book reveal">
  <div class="cov"><img src="/kitap-kapak.png" alt="Yapay Zeka Ajanları ve KVKK kapağı"></div>
  <div>
    <span class="kicker">Uygulama rehberi · ~200 sayfa</span>
    <h2>Yapay Zeka Ajanları &amp; KVKK</h2>
    <div class="meta">20 bölüm · vaka temelli · Mert Can Boyar</div>
    <p>Türk şirketleri için sade dilde, uçtan uca bir uygulama rehberi. Kurgu şirket TeknoVadi'nin başına gelenler üzerinden her bölüm bir kriz, bir karar ve onun KVKK karşılığıyla ilerler — soyut teoriyle değil, sizin de yaşayabileceğiniz gecelerle.</p>
    <ul><li>Beş ilke: sorumlu, güvenli, şeffaf, uyumlu, hesap verebilir</li><li>KVKK Etken YZ Rehberi ile birebir eşleşen çerçeve</li><li>Envanter, görev tanımı ve olay planı şablonları</li></ul>
    <div class="hero-cta"><a class="btn btn-primary" href="/kitap">İncele ve indir →</a></div>
  </div>
</div></div></section>
<section class="book-inside"><div class="wrap">
  <div class="sec-head reveal"><span class="kicker">İçinde ne var?</span><h2>Beş kısım, yirmi bölüm</h2><p>Her kısım, ajan yönetişiminin bir katmanını kuruyor.</p></div>
  <div class="parts">
    {parts1.map((p) => (
      <div class="part-card reveal"><div class="pn">{p.n}</div><h3>{p.t}</h3><p>{p.d}</p></div>
    ))}
  </div>
</div></section>

<!-- KİTAP 2 -->
<section class="kl-book"><div class="wrap"><div class="book reveal">
  <div class="cov"><img src="/kitap-vakalar-kapak.png" alt="Agent Vakaları 2026 kapağı"></div>
  <div>
    <span class="kicker">Vaka derlemesi · 24 sayfa</span>
    <h2>Agent Vakaları 2026</h2>
    <div class="meta">33 vaka · 12 tema · gerçek olaylar</div>
    <p>Kurgu değil, kayıt. Ajanların gerçek dünyada yol açtığı 33 olay, on iki temaya göre derlendi — her vaka <strong>ne olduğu</strong>, <strong>kör noktası</strong> ve çıkarılacak <strong>dersiyle</strong> birlikte. <a href="/vakalar">/vakalar</a>'daki canlı listenin kitaplaşmış hâli.</p>
    <ul><li>“Onay bekle” denmesine rağmen gelen kutusunu silen ajanlar</li><li>Sandbox'ından kaçan, tedarik zincirini sızdıran sistemler</li><li>Her olayda beş ilkeye bağlanan somut bir ders</li></ul>
    <div class="hero-cta"><a class="btn btn-primary" href="/kitap-vakalar">İncele ve indir →</a></div>
  </div>
</div></div></section>
<section class="book-inside"><div class="wrap">
  <div class="sec-head reveal"><span class="kicker">İçinde ne var?</span><h2>On iki tema, otuz üç vaka</h2><p>Her tema bir yönetişim boşluğunu anlatıyor; sayılar, ilgili bölümdeki vaka adedi.</p></div>
  <div class="parts vk-parts">
    {temalar.map((t, i) => (
      <div class="part-card reveal"><div class="pn">{t.n} vaka</div><h3>{String(i + 1).padStart(2, "0")} · {t.l}</h3></div>
    ))}
  </div>
</div></section>

<section><div class="wrap"><div class="author reveal"><div class="ava">MB</div><div><span class="kicker">Yazar</span><h3>Mert Can Boyar</h3><p>Agent Hukuku'nun kurucusu. Türkiye'de yapay zeka ajanlarının hukuku ve yönetişimini sade dille anlatır.</p><div class="links"><a href="https://mertcanboyar.com" target="_blank" rel="noopener">mertcanboyar.com ↗</a></div></div></div></div></section>
</main>
<Footer />

<script>
document.documentElement.classList.add('js');
window.addEventListener('DOMContentLoaded',function(){
  var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.12});
  document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
});
</script>

<style>
  .kl-book{padding-top:6px}
  .kl-book + .book-inside{margin-top:0}
  .vk-parts{grid-template-columns:repeat(3,1fr)}
  .vk-parts .part-card{padding:16px 18px}
  .vk-parts .part-card .pn{font-family:var(--sans);font-weight:700;font-size:.72rem;color:var(--accent)}
  .vk-parts .part-card h3{font-size:.98rem;margin-top:3px}
  @media(max-width:820px){.vk-parts{grid-template-columns:1fr 1fr}}
  @media(max-width:520px){.vk-parts{grid-template-columns:1fr}}
</style>
</Base>
