---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<Base title="Ajan Yönetişimi Olgunluk Testi — Agent Hukuku" description="15 soruda şirketinizin yapay zeka ajanı yönetişimi olgunluğunu ölçün; radar grafikli SaaS panosu, KPI'lar ve önceliklendirilmiş aksiyon planı.">
<Header />
<main class="assess-page"><div class="wrap"><div class="quiz-wrap">
  <section id="intro" class="quiz-intro">
    <span class="kicker">İnteraktif değerlendirme</span>
    <h1>Ajan Yönetişimi Olgunluk Testi</h1>
    <p class="lead">17 kısa adımda şirketinizin yapay zeka ajanlarını ne kadar sorumlu yönettiğini ölçün. Sonunda SaaS panosu gibi bir olgunluk karnesi, radar grafiği ve önceliklendirilmiş aksiyon planı alırsınız.</p>
    <div class="quiz-facts"><div class="f"><b>15</b><span>değerlendirme sorusu</span></div><div class="f"><b>~4 dk</b><span>süre</span></div><div class="f"><b>Panolu</b><span>karne</span></div></div>
    <button class="btn btn-primary" onclick="startQuiz()">Teste başla →</button>
    <p class="hint" style="margin-top:1rem">Kayıt gerekmez. Cevaplarınız yalnızca skorunuzu hesaplamak için kullanılır.</p>
  </section>
  <section id="quiz" class="hidden">
    <div class="progress"><div class="p" id="prog"></div></div>
    <div class="progress-lbl"><span id="progtxt"></span><span id="pillartxt"></span></div>
    <div class="q-card"><div class="q-pillar" id="qpillar"></div><div class="q-text" id="qtext"></div><div class="opts" id="opts"></div></div>
    <div class="quiz-nav"><button class="btn btn-ghost" id="backBtn" onclick="prevQ()">← Geri</button><button class="btn btn-primary" id="nextBtn" onclick="nextQ()" disabled>Devam →</button></div>
  </section>
  <section id="result" class="hidden">
    <div style="text-align:center;margin-bottom:26px"><span class="kicker">Olgunluk Panosu</span><h1 style="font-size:clamp(1.7rem,3.5vw,2.3rem);margin-top:.4rem">Ajan Yönetişimi Karneniz</h1></div>
    <div id="dash"></div>
    <div class="result-cta">
      <h3>Detaylı panoyu PDF olarak alın</h3>
      <p>Kişisel karneniz + "Yapay Zeka Ajanları &amp; KVKK" kitabı e-postanıza gelsin.</p>
      <form data-lead="degerlendirme"><input type="email" id="leadEmail" placeholder="Çalışma e-postanız" required><button class="btn btn-primary" type="submit">Panomu ve kitabı gönder</button><label class="consent"><input type="checkbox" class="cbox" required><span>KVKK kapsamında e-postamın işlenmesine ve tarafıma bilgilendirme/pazarlama iletisi gönderilmesine <a href="/aydinlatma" target="_blank">Aydınlatma Metni</a> uyarınca açık rıza veriyorum.</span></label></form>
      <div id="leadThanks" class="hidden" style="color:#2f6b60;font-weight:600;margin-bottom:.8rem"></div>
      <button class="retry" onclick="restart()">Testi yeniden çöz</button>
    </div>
  </section>
</div></div></main>
<Footer />
<script is:inline>
document.documentElement.classList.add('js');
var PILLARS=["Sorumlu","Güvenli","Şeffaf","Uyumlu","Hesap Verebilir"];
var PSHORT=["Sorumlu","Güvenli","Şeffaf","Uyumlu","Hesap"];
var OPTS=[{l:"Hayır — yok",v:0},{l:"Kısmen / gayrıresmî",v:1},{l:"Büyük ölçüde var",v:2},{l:"Evet — ve kanıtlayabilirim",v:3}];
var STEPS=[
 {k:"ctx",t:"Şirketiniz kaç kişi?",o:["1–10","11–50","51–250","250+"]},
 {k:"ctx",t:"Kaç yapay zeka ajanı / otomasyonu kullanıyorsunuz?",o:["Henüz yok / pilot","1–3","4–10","10+"]},
 {k:"q",p:0,t:"Şirketinizdeki tüm ajanların (bot, otomasyon, asistan dahil) listesi tek bir yerde tutuluyor mu?"},
 {k:"q",p:0,t:"Her ajanın yazılı bir amacı ve isimle atanmış bir sahibi var mı?"},
 {k:"q",p:0,t:"Yeni bir ajan devreye girmeden önce bir onay/kayıt sürecinden geçiyor mu?"},
 {k:"q",p:1,t:"Her ajan yalnızca işi için gerekli veriye mi erişiyor — yoksa erişebildiği her şeye mi?"},
 {k:"q",p:1,t:"Bir ajanı beş dakika içinde durdurabilecek kişi ve yöntem belli mi?"},
 {k:"q",p:1,t:"Ajanlar kişisel hesap yerine kendi kimlikleriyle (servis hesabı) mı çalışıyor?"},
 {k:"q",p:2,t:"Müşterileriniz ne zaman bir ajanla muhatap olduklarını biliyor mu?"},
 {k:"q",p:2,t:"Çalışanlarınız hangi süreçlerinde ajan kullanıldığından haberdar mı?"},
 {k:"q",p:2,t:"Bir ajanın belirli bir kararı neden verdiği gerektiğinde açıklanabiliyor mu?"},
 {k:"q",p:3,t:"Ajanların dokunduğu kişisel veriler için hangi işleme şartına (KVKK m.5) dayandığınızı söyleyebilir misiniz?"},
 {k:"q",p:3,t:"Ajan tedarikçilerinizle imzalı bir veri işleme sözleşmeniz var mı?"},
 {k:"q",p:3,t:"Yurt dışında işlenen veriler için bir aktarım mekanizmanız (ör. standart sözleşme) var mı?"},
 {k:"q",p:4,t:"“Bu ajan dün saat 14:00te hangi verilere dokundu?” sorusuna kayıtla cevap verebilir misiniz?"},
 {k:"q",p:4,t:"Bir şey ters gittiğinde işleyecek, yazılı bir olay müdahale planınız var mı?"},
 {k:"q",p:4,t:"Riskli/onaya düşen işlemlerin kaydı (kim, ne zaman, hangi gerekçe) tutuluyor mu?"}
];
var RECS=[
 {t:"Görünürlüğü kurun",d:"Tüm ajanların envanterini çıkarın ve her birine isimle bir sahip atayın.",c:"Bölüm 2 & 4"},
 {t:"Erişimi ve durdurmayı sıkılaştırın",d:"Ayrı kimlik + en az yetki verin; acil durdurmayı test edin.",c:"Bölüm 5, 6, 8, 9"},
 {t:"Şeffaflığı sağlayın",d:"Ajan kullanımını açıkça bildirin; kararların izlenebilirliğini kurun.",c:"Bölüm 10 & 11"},
 {t:"Hukuki zemini tamamlayın",d:"İşleme şartlarını netleştirin, sözleşme ve aktarımı düzenleyin.",c:"Bölüm 14, 16, 17"},
 {t:"Hesap verebilirliği inşa edin",d:"Denetim izi + tek sayfalık olay müdahale planı oluşturun.",c:"Bölüm 10 & 18"}
];
var ans=new Array(STEPS.length).fill(null), cur=0, TOTAL=STEPS.length;

function startQuiz(){document.getElementById('intro').classList.add('hidden');document.getElementById('quiz').classList.remove('hidden');cur=0;renderStep();scrollTop();}
function scrollTop(){window.scrollTo({top:0,behavior:'smooth'});}
function renderStep(){
  var s=STEPS[cur];
  document.getElementById('prog').style.width=(cur/TOTAL*100)+'%';
  document.getElementById('progtxt').textContent='Adım '+(cur+1)+' / '+TOTAL;
  document.getElementById('pillartxt').textContent=s.k==='ctx'?'Bağlam':PILLARS[s.p];
  document.getElementById('qpillar').textContent=s.k==='ctx'?'Bağlam':PILLARS[s.p];
  document.getElementById('qtext').textContent=s.t;
  var opts=s.k==='ctx'?s.o.map(function(l,i){return {l:l,v:i};}):OPTS;
  var o=document.getElementById('opts');o.innerHTML='';
  opts.forEach(function(op){
    var b=document.createElement('button');b.className='opt'+(ans[cur]===op.v?' sel':'');
    b.innerHTML='<span class="rb"></span>'+op.l;
    b.onclick=function(){ans[cur]=op.v;renderStep();document.getElementById('nextBtn').disabled=false;};
    o.appendChild(b);
  });
  document.getElementById('backBtn').style.visibility=cur===0?'hidden':'visible';
  document.getElementById('nextBtn').disabled=ans[cur]===null;
  document.getElementById('nextBtn').textContent=cur===TOTAL-1?'Karnemi gör →':'Devam →';
}
function nextQ(){if(ans[cur]===null)return;if(cur<TOTAL-1){cur++;renderStep();scrollTop();}else{showResult();}}
function prevQ(){if(cur>0){cur--;renderStep();}}

function ptc(cx,cy,r,i){var a=(i*72-90)*Math.PI/180;return [cx+r*Math.cos(a),cy+r*Math.sin(a)];}
function radar(pcts){
  var cx=150,cy=145,R=100,svg='<svg viewBox="0 0 300 290" width="300" height="290">';
  [0.25,0.5,0.75,1].forEach(function(L){var pts=[];for(var i=0;i<5;i++){var p=ptc(cx,cy,R*L,i);pts.push(p[0].toFixed(1)+','+p[1].toFixed(1));}svg+='<polygon points="'+pts.join(' ')+'" fill="none" stroke="#e2e8ef" stroke-width="1"/>';});
  for(var i=0;i<5;i++){var p=ptc(cx,cy,R,i);svg+='<line x1="'+cx+'" y1="'+cy+'" x2="'+p[0].toFixed(1)+'" y2="'+p[1].toFixed(1)+'" stroke="#e2e8ef" stroke-width="1"/>';}
  var dp=[];for(var i=0;i<5;i++){var p=ptc(cx,cy,R*(pcts[i]/100),i);dp.push(p[0].toFixed(1)+','+p[1].toFixed(1));}
  svg+='<polygon points="'+dp.join(' ')+'" fill="rgba(47,109,158,.18)" stroke="#2F6D9E" stroke-width="2"/>';
  for(var i=0;i<5;i++){var p=ptc(cx,cy,R*(pcts[i]/100),i);svg+='<circle cx="'+p[0].toFixed(1)+'" cy="'+p[1].toFixed(1)+'" r="3.5" fill="#2F6D9E"/>';}
  for(var i=0;i<5;i++){var p=ptc(cx,cy,R+18,i);svg+='<text x="'+p[0].toFixed(1)+'" y="'+(p[1]+4).toFixed(1)+'" text-anchor="middle" font-family="Inter,sans-serif" font-size="11" font-weight="600" fill="#48566a">'+PSHORT[i]+'</text>';}
  return svg+'</svg>';
}
function ring(pct,size,sw){var r=(size/2)-sw, C=2*Math.PI*r, d=(pct/100*C).toFixed(1);return '<svg width="'+size+'" height="'+size+'" viewBox="0 0 '+size+' '+size+'"><circle cx="'+size/2+'" cy="'+size/2+'" r="'+r+'" fill="none" stroke="#E4ECF4" stroke-width="'+sw+'"/><circle cx="'+size/2+'" cy="'+size/2+'" r="'+r+'" fill="none" stroke="#2F6D9E" stroke-width="'+sw+'" stroke-linecap="round" stroke-dasharray="'+d+' '+C.toFixed(1)+'"/></svg>';}

function showResult(){
  document.getElementById('prog').style.width='100%';
  document.getElementById('quiz').classList.add('hidden');
  document.getElementById('result').classList.remove('hidden');
  var psum=[0,0,0,0,0],pcnt=[0,0,0,0,0],gaps=0,tot=0,tc=0;
  STEPS.forEach(function(s,i){if(s.k==='q'){psum[s.p]+=ans[i];pcnt[s.p]++;tot+=ans[i];tc++;if(ans[i]===0)gaps++;}});
  var pcts=psum.map(function(x,i){return Math.round(x/(pcnt[i]*3)*100);});
  var total=Math.round(tot/(tc*3)*100);
  var strong=pcts.indexOf(Math.max.apply(null,pcts)), weak=pcts.indexOf(Math.min.apply(null,pcts));
  var band,verdict,sum;
  if(total<40){band='<span class="band low">Başlangıç</span>';verdict='Temeli kurma zamanı';sum='Ajanlar iş görüyor ama yönetişim henüz kurulmamış. En büyük kazanımlar önünüzde — aşağıdaki önceliklerden başlayın.';}
  else if(total<70){band='<span class="band mid">Gelişmekte</span>';verdict='İyi yoldasınız';sum='Temel bazı yerlerde var ama boşluklar risk taşıyor. Zayıf alanları kapatarak hızla olgunlaşabilirsiniz.';}
  else{band='<span class="band high">Olgun</span>';verdict='Güçlü bir yönetişim';sum='Ajanlarınızı bilinçli yönetiyorsunuz. Bundan sonrası sürekliliği ve kanıtlanabilirliği korumak.';}
  var size=["1–10","11–50","51–250","250+"][ans[0]]||"—";
  var agents=["Henüz yok / pilot","1–3","4–10","10+"][ans[1]]||"—";
  function stat(p){return p>=70?['ok','Güçlü']:p>=40?['warn','Orta']:['risk','Zayıf'];}
  var order=[0,1,2,3,4].sort(function(a,b){return pcts[a]-pcts[b];}).slice(0,3);

  var h='';
  // hero
  h+='<div class="dash-hero"><div class="dh-gauge">'+ring(total,170,13)+'<div class="val"><span class="num">'+total+'</span><span class="of">/ 100</span></div></div>'
   +'<div class="dh-body">'+band+'<h2>'+verdict+'</h2><p class="sum">'+sum+'</p>'
   +'<div class="dh-profile"><span class="chip">Şirket: '+size+' kişi</span><span class="chip">Ajan: '+agents+'</span></div>'
   +'<div class="target"><div class="tt"><span>Durumunuz: '+total+'</span><span>Olgun eşiği: 80</span></div><div class="track"><div class="fill" style="width:'+total+'%"></div><div class="mk" style="left:80%"><span>80</span></div></div></div>'
   +'</div></div>';
  // kpis
  h+='<div class="kpis">'
   +'<div class="kpi"><div class="lab">Genel olgunluk</div><div class="big">'+total+'<span style="font-size:.9rem;color:var(--muted)">/100</span></div><div class="sub">'+(gaps>0?gaps+' kritik boşluk':'kritik boşluk yok')+'</div></div>'
   +'<div class="kpi"><div class="lab">En güçlü ilke</div><div class="big" style="font-size:1.2rem">'+PILLARS[strong]+'</div><div class="sub">%'+pcts[strong]+' olgunluk</div></div>'
   +'<div class="kpi"><div class="lab">En zayıf ilke</div><div class="big" style="font-size:1.2rem">'+PILLARS[weak]+'</div><div class="sub">%'+pcts[weak]+' olgunluk</div></div>'
   +'<div class="kpi"><div class="lab">Kritik boşluk</div><div class="big">'+gaps+'<span style="font-size:.9rem;color:var(--muted)"> soru</span></div><div class="sub">"yok" yanıtı</div></div>'
   +'</div>';
  // 2col: radar + plan
  var plan='';order.forEach(function(i){var r=RECS[i];var tag=pcts[i]<40?['hi','Yüksek']:['mid','Orta'];plan+='<div class="plan-item"><span class="pri-tag '+tag[0]+'">'+tag[1]+'</span><div><div class="pt">'+r.t+'</div><div class="pd">'+r.d+' <b style="color:var(--ink-2)">('+PILLARS[i]+' %'+pcts[i]+')</b></div><div class="ch">→ '+r.c+'</div></div></div>';});
  h+='<div class="dash-2col"><div class="dcard"><h3>İlke radarı</h3><div class="cap">Beş ilkede olgunluk dağılımınız</div><div class="radar-wrap">'+radar(pcts)+'</div></div>'
   +'<div class="dcard"><h3>Öncelikli aksiyon planı</h3><div class="cap">En hızlı kazanımı bu üç alanda elde edersiniz</div>'+plan+'</div></div>';
  // pillar cards
  var pcs='';PILLARS.forEach(function(nm,i){var st=stat(pcts[i]);pcs+='<div class="pc2"><div class="ring2">'+ring(pcts[i],64,7)+'<div class="v">'+pcts[i]+'</div></div><div class="nm">'+nm+'</div><span class="tag '+st[0]+'">'+st[1]+'</span></div>';});
  h+='<div class="pillar-cards">'+pcs+'</div>';

  window.__leadMeta=function(){return {total:total,pillars:pcts,size:size,agents:agents,answers:ans.slice(2)};};
  document.getElementById('dash').innerHTML=h;
  scrollTop();
}
/* Panonun e-posta gönderimi, form[data-lead="degerlendirme"] üzerinden Base.astro'daki
   global işleyiciyle /api/lead'e yapılır (meta = window.__leadMeta ile total + pillars). */
function restart(){ans=new Array(STEPS.length).fill(null);cur=0;document.getElementById('result').classList.add('hidden');document.getElementById('intro').classList.remove('hidden');scrollTop();}
</script>
</Base>
