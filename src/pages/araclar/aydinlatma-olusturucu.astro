---
import Base from "../../layouts/Base.astro";
import AppShell from "../../components/AppShell.astro";

const faq = [
  { q: "Bu araç KVKK m.10'a uygun bir aydınlatma metni mi üretir?", a: "Seçimlerinize göre m.10'daki temel unsurları — veri sorumlusunun kimliği, işleme amacı, aktarım ve ilgili kişinin hakları — içeren bir taslak üretir. Taslağı kendi sürecinize göre uyarlamanız gerekir." },
  { q: "Ajan kullandığımı aydınlatma metninde belirtmem gerekir mi?", a: "Şeffaflık ilkesi gereği, kişisel veriyi bir yapay zeka ajanıyla işliyorsanız ilgili kişiyi bunun hakkında bilgilendirmeniz beklenir. Bu araç tam da bunu açıkça söyleyen bir bildirim üretir." },
  { q: "Girdiğim bilgiler bir sunucuya gönderiliyor mu?", a: "Hayır. Araç tamamen tarayıcınızda çalışır; girdiğiniz hiçbir bilgi sunucuya gönderilmez veya saklanmaz." },
  { q: "Üretilen metin hukuki tavsiye yerine geçer mi?", a: "Hayır. Üretilen metin genel bilgilendirme amaçlı bir taslaktır ve hukuki tavsiye niteliği taşımaz; gerektiğinde bir hukukçuya danışın." },
];
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faq.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };
---
<Base title="Aydınlatma Metni Oluşturucu (Yapay Zeka Ajanı) | Agent Hukuku" description="Ajan kullandığınızı söyleyen, KVKK m.10'a uygun bir aydınlatma metnini birkaç seçimle üretin. E-posta, sohbet ve telefon için kısa bildirimlerle. Ücretsiz.">
<Fragment slot="head"><script type="application/ld+json" set:html={JSON.stringify(faqSchema)} /></Fragment>
<AppShell active="aydinlatma" title="Aydınlatma Metni Oluşturucu">
<section class="page-hero"><div class="wrap">
  <div class="breadcrumb"><a href="/araclar">Araçlar</a> · Aydınlatma metni oluşturucu</div>
  <span class="kicker">Araç</span>
  <h1>Aydınlatma metni oluşturucu</h1>
  <p class="lead">Ajanınız için m.10'a uygun bir aydınlatma metni ve üç kanal (e-posta, sohbet, telefon) için kısa bildirimler üretin. Seçim yaptıkça sağdaki metin güncellenir.</p>
</div></section>
<section class="tex-showcase"><div class="wrap">
  <div class="tex-head"><span class="kicker">Sonuç böyle görünür</span><span class="tex-note">Örnek — seçimlerinizle anında güncellenir, Word olarak inersiniz.</span></div>
  <div class="card-ui tex" style="max-width:760px">
    <div class="mui-head"><div class="mui-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/><path d="M9 13h6M9 17h4"/></svg> Aydınlatma Metni</div><div class="mui-live">önizleme</div></div>
    <div class="tex-doc">
      <h4>TEKNOVADİ A.Ş. — Kişisel Verilerin İşlenmesine İlişkin Aydınlatma Metni</h4>
      <div class="dl">(Yapay Zeka Asistanı Kullanımı Hakkında)</div>
      <p>Veri sorumlusu sıfatıyla, “Destek Asistanı” aracılığıyla kişisel verilerinizi 6698 sayılı KVKK kapsamında işliyoruz. Bu asistan bir yapay zeka sistemidir; “temsilci” yazarak bir kişiye bağlanabilirsiniz.</p>
      <div class="sec">1) İşlenen kişisel veriler</div>
      <p>Ad-soyad ve iletişim bilgileri · Hesap/işlem bilgileri · Talep ve mesaj içerikleri</p>
      <div class="sec">3) Hukuki sebep (KVKK m.5)</div>
      <p>Sözleşmenin kurulması veya ifası · Hizmet kalitesi ve güvenliğinin sağlanması</p>
    </div>
  </div>
</div></section>

<section style="padding-top:6px"><div class="wrap">
  <div class="tool-grid">
    <form class="tool-form" id="f" autocomplete="off">
      <div class="field"><label for="sirket">Veri sorumlusu (şirket/kişi)</label><input type="text" id="sirket" placeholder="Örn. TeknoVadi Yazılım A.Ş."></div>
      <div class="field"><label for="iletisim">Başvuru / iletişim adresi</label><input type="text" id="iletisim" placeholder="Örn. kvkk@sirketiniz.com"></div>
      <div class="field"><label for="ajan">Asistan/ajan adı</label><input type="text" id="ajan" placeholder="Örn. Destek Asistanı"></div>

      <div class="field"><label>Kanallar</label><div class="chk" id="kanallar">
        <label><input type="checkbox" value="e-posta" checked>E-posta</label>
        <label><input type="checkbox" value="canlı sohbet" checked>Canlı sohbet</label>
        <label><input type="checkbox" value="telefon/sesli asistan">Telefon (sesli)</label>
        <label><input type="checkbox" value="web sitesi">Web sitesi</label>
      </div></div>

      <div class="field"><label>İşlenen kişisel veriler</label><div class="chk" id="veriler">
        <label><input type="checkbox" value="ad-soyad ve iletişim bilgileri" checked>İletişim bilgileri</label>
        <label><input type="checkbox" value="hesap ve işlem bilgileri" checked>Hesap/işlem bilgileri</label>
        <label><input type="checkbox" value="talep ve mesaj içerikleri" checked>Talep/mesaj içeriği</label>
        <label><input type="checkbox" value="ses kayıtları">Ses kaydı</label>
        <label><input type="checkbox" value="kullanım ve log verileri">Kullanım/log verileri</label>
      </div></div>

      <div class="field"><label>İşleme amaçları</label><div class="chk" id="amaclar">
        <label><input type="checkbox" value="destek taleplerinizi çözmek" checked>Destek</label>
        <label><input type="checkbox" value="ürün ve hizmetlerimizi sunmak" checked>Hizmet sunumu</label>
        <label><input type="checkbox" value="işlemlerinizi yürütmek">İşlem yürütme</label>
        <label><input type="checkbox" value="pazarlama ve bilgilendirme iletileri göndermek">Pazarlama</label>
        <label><input type="checkbox" value="hizmet kalitesi ve güvenliğini sağlamak" checked>Kalite/güvenlik</label>
      </div></div>

      <div class="field"><label>Hukuki sebep (KVKK m.5)</label><div class="chk" id="sebep">
        <label><input type="checkbox" value="sözleşmenin kurulması veya ifası" checked>Sözleşmenin ifası</label>
        <label><input type="checkbox" value="meşru menfaat">Meşru menfaat</label>
        <label><input type="checkbox" value="hukuki yükümlülük">Hukuki yükümlülük</label>
        <label><input type="checkbox" value="açık rıza">Açık rıza</label>
      </div><div class="hint">İpucu: Açık rıza son çaredir; çalışan verilerinde rızaya güvenmeyin.</div></div>

      <div class="field"><label for="yurtdisi">Yurt dışına aktarım var mı?</label><select id="yurtdisi"><option value="hayir">Hayır</option><option value="evet">Evet (ör. model çıkarımı yurt dışında)</option></select></div>
      <div class="field"><label for="otomatik">Otomatik karar / profilleme var mı?</label><select id="otomatik"><option value="hayir">Hayır</option><option value="evet">Evet</option></select></div>
    </form>

    <div class="tool-out">
      <div class="tool-out-head"><span class="t">Oluşturulan metin</span><div class="acts"><button type="button" class="tool-btn" id="copy">Kopyala</button><button type="button" class="tool-btn" id="dl" data-gate="aydinlatma">İndir</button></div></div>
      <div class="tool-doc" id="out"></div>
    </div>
  </div>
  <p class="tool-note" style="max-width:820px">Bu araç, tarayıcınızda çalışır; girdiğiniz hiçbir bilgi sunucuya gönderilmez. Üretilen metin bir taslaktır ve hukuki tavsiye niteliği taşımaz — kendi durumunuza göre uyarlayın.</p>
</div></section>
<section class="faq-sec"><div class="wrap">
  <h2 class="faq-h">Sıkça sorulan sorular</h2>
  <div class="faq-list">
    {faq.map((f) => (
      <details class="faq-item"><summary>{f.q}</summary><div class="faq-a">{f.a}</div></details>
    ))}
  </div>
</div></section>
</AppShell>

<script>
  const $ = (id) => document.getElementById(id);
  const checked = (id) => [...$(id).querySelectorAll('input:checked')].map(i => i.value);
  const list = (arr) => arr.length ? arr.map(x => "  • " + x.charAt(0).toUpperCase() + x.slice(1)).join("\n") : "  • —";

  function build(){
    const sirket = ($('sirket').value || "[Şirket adı]").trim();
    const iletisim = ($('iletisim').value || "[iletişim adresi]").trim();
    const ajan = ($('ajan').value || "Yapay Zeka Asistanı").trim();
    const kanallar = checked('kanallar');
    const kanalStr = kanallar.length ? kanallar.join(", ") : "dijital kanallarımız";
    const veriler = checked('veriler');
    const amaclar = checked('amaclar');
    const sebep = checked('sebep');
    const yurtdisi = $('yurtdisi').value === "evet";
    const otomatik = $('otomatik').value === "evet";

    let t = "";
    t += sirket.toUpperCase() + " — KİŞİSEL VERİLERİN İŞLENMESİNE İLİŞKİN AYDINLATMA METNİ\n";
    t += "(Yapay Zeka Asistanı Kullanımı Hakkında)\n\n";
    t += "Veri sorumlusu sıfatıyla " + sirket + " olarak, " + kanalStr + " üzerinden sunduğumuz “" + ajan + "” aracılığıyla kişisel verilerinizi 6698 sayılı Kişisel Verilerin Korunması Kanunu (KVKK) kapsamında işliyoruz. Bu asistan bir yapay zeka sistemidir; dilediğiniz an “temsilci” yazarak/diyerek ekibimizden bir kişiye bağlanabilirsiniz.\n\n";
    t += "1) İŞLENEN KİŞİSEL VERİLER\n" + list(veriler) + "\n\n";
    t += "2) İŞLEME AMAÇLARI\n" + list(amaclar) + "\n\n";
    t += "3) HUKUKİ SEBEP (KVKK m.5)\nVerileriniz, aşağıdaki hukuki sebeplere dayanılarak işlenmektedir:\n" + list(sebep) + "\n\n";
    t += "4) AKTARIM\n";
    t += yurtdisi
      ? "Verileriniz, hizmetin sağlanması amacıyla (ör. yapay zeka modelinin çalıştırılması) yurt dışındaki hizmet sağlayıcılarımıza, KVKK m.9 kapsamında uygun güvencelerle aktarılabilir.\n\n"
      : "Verileriniz yalnızca hizmetin gereği ve yasal yükümlülükler kapsamında paylaşılır; bunun dışında üçüncü kişilere aktarılmaz.\n\n";
    if (otomatik) {
      t += "5) OTOMATİK KARAR VE PROFİLLEME\nVerileriniz, hakkınızda sonuç doğuran otomatik değerlendirmeler içeren süreçlerde işlenebilir. Böyle bir karara itiraz etme, görüşünüzü ifade etme ve kararın bir insan tarafından gözden geçirilmesini talep etme hakkına sahipsiniz.\n\n";
    }
    const n = otomatik ? "6" : "5";
    t += n + ") HAKLARINIZ (KVKK m.11)\nKişisel verilerinizle ilgili KVKK m.11'de sayılan haklarınızı (işlenip işlenmediğini öğrenme, bilgi talep etme, düzeltme, silme/yok etme, itiraz etme ve zararın giderilmesini isteme) " + iletisim + " adresine başvurarak kullanabilirsiniz. Başvurunuz en geç 30 gün içinde sonuçlandırılır.\n\n";
    t += "————————————————————\n";
    t += "KANAL BİLDİRİMLERİ (kopyalayıp kullanın)\n\n";
    if (kanallar.includes("e-posta"))
      t += "• E-posta imzası:\n“Bu yanıt " + sirket + " " + ajan + "'ı (yapay zeka) tarafından hazırlanmıştır. Bir insanla görüşmek için bu e-postaya ‘temsilci’ yazmanız yeterli. Aydınlatma metni: [bağlantı].”\n\n";
    if (kanallar.includes("canlı sohbet"))
      t += "• Sohbet ilk mesajı:\n“Merhaba! Ben " + sirket + "'in yapay zeka destek asistanıyım. Dilediğiniz an ‘temsilci’ yazarak bir kişiye bağlanabilirsiniz. Yazışmalarımız hizmet kalitesi ve destek amacıyla kaydedilir — ayrıntılar: [aydınlatma metni].”\n\n";
    if (kanallar.includes("telefon/sesli asistan"))
      t += "• Telefon karşılaması:\n“" + sirket + "'e hoş geldiniz. Şu anda yapay zeka asistanımızla görüşüyorsunuz; görüşmemiz kayıt altına alınmaktadır. Dilediğiniz an ‘temsilci’ diyerek müşteri temsilcimize bağlanabilirsiniz.”\n\n";
    t += "————————————————————\n";
    t += "Bu metin genel bilgilendirme amaçlıdır ve hukuki tavsiye niteliği taşımaz.";
    return t;
  }

  function render(){ $('out').textContent = build(); }
  $('f').addEventListener('input', render);
  $('copy').addEventListener('click', async () => {
    try { await navigator.clipboard.writeText(build()); $('copy').textContent = "Kopyalandı ✓"; setTimeout(()=>$('copy').textContent="Kopyala",1500); } catch(e){}
  });
  $('dl').addEventListener('click', () => { window.AH.downloadWord("aydinlatma-metni.doc", "Aydınlatma Metni", build()); });
  render();
</script>
</Base>
