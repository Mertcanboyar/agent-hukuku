---
import Base from "../../layouts/Base.astro";
import AppShell from "../../components/AppShell.astro";

const faq = [
  { q: "Neden tedarikçi değerlendirmesi gerekir?", a: "Ajanınızın kullandığı her tedarikçi ve model, sizin saldırı yüzeyiniz ve KVKK sorumluluğunuzun bir parçasıdır. Yeni bir ajanı almadan önce veri yeri, güvenlik, durdurma ve sözleşme gibi başlıkları sormak, sonradan sürprizle karşılaşmayı önler." },
  { q: "Veri işleme sözleşmesi (DPA) neden önemli?", a: "Sizin adınıza kişisel veri işleyen her tedarikçiyle yazılı bir veri işleme sözleşmesi imzalanmalıdır; 'kullanım koşulları' bunun yerine geçmez. DPA yoksa, tedarikçinin hatası doğrudan sizin sorumluluğunuza döner." },
  { q: "Veri yurt dışında işleniyorsa ne olur?", a: "Yurt dışına veri aktarımı KVKK m.9 kapsamında uygun bir mekanizma (genelde standart sözleşme) gerektirir ve aydınlatma metnine işlenir. Bu araç riski işaret eder; mekanizmanın kurulması sizin sorumluluğunuzdadır." },
  { q: "Üretilen belge hukuki tavsiye midir?", a: "Hayır. Üretilen değerlendirme genel bilgilendirme amaçlı bir taslaktır ve hukuki tavsiye yerine geçmez; girdiğiniz bilgiler tarayıcınızdan çıkmaz." },
];
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faq.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };
---
<Base title="Tedarikçi Değerlendirme Oluşturucu — Yapay Zeka Ajanı | Agent Hukuku" description="Yeni bir ajan almadan önce doğru soruları sorun: veri yeri, DPA, güvenlik sertifikaları, durdurma, olay bildirimi ve şeffaflık. Tek sayfalık due diligence formunu Word olarak indirin.">
<Fragment slot="head"><script type="application/ld+json" set:html={JSON.stringify(faqSchema)} /></Fragment>
<AppShell active="tedarikci" title="Tedarikçi Değerlendirme Oluşturucu">
<section class="page-hero"><div class="wrap">
  <div class="breadcrumb"><a href="/araclar">Araçlar</a> · Tedarikçi değerlendirme</div>
  <span class="kicker">Araç</span>
  <h1>Tedarikçi değerlendirme oluşturucu</h1>
  <p class="lead">Yeni bir ajan ya da model almadan önce doğru soruları sorun. Birkaç seçimle tek sayfalık bir due diligence (durum tespiti) belgesi çıkarın — veri yerinden sözleşmeye, durdurmadan şeffaflığa.</p>
</div></section>

<section class="tex-showcase"><div class="wrap">
  <div class="tex-head"><span class="kicker">Sonuç böyle görünür</span><span class="tex-note">Örnek — seçimlerinizle oluşur, Word olarak inersiniz.</span></div>
  <div class="card-ui tex" style="max-width:760px">
    <div class="mui-head"><div class="mui-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="4.5"/><path d="M10.5 12.5L20 3M17 6l2 2M14 9l2 2"/></svg> Tedarikçi Değerlendirme</div><div class="mui-live">önizleme</div></div>
    <div class="tex-doc">
      <h4>Tedarikçi Değerlendirme (Due Diligence) — Taslak</h4>
      <div class="dl">Tedarikçi: Örnek Ajan Platformu · Değerlendiren: A. Yılmaz</div>
      <div class="sec">Veri ve aktarım</div>
      <p>Verinin işlendiği yer: Yurt dışı · DPA: Görüşülüyor</p>
      <div class="sec">Güvenlik</div>
      <p>Sertifikalar: ISO 27001, SOC 2 · Alt-işleyenler açıklanıyor: Evet</p>
      <div class="sec">Kontrol</div>
      <p>Acil durdurma: Var · Olay bildirim taahhüdü: Sözleşmede var</p>
    </div>
  </div>
</div></section>

<section style="padding-top:6px"><div class="wrap">
  <div class="tool-grid">
    <form class="tool-form" id="f" autocomplete="off">
      <div class="field"><label for="tedarikci">Tedarikçi / ürün adı</label><input type="text" id="tedarikci" placeholder="Örn. Örnek Ajan Platformu"></div>
      <div class="field"><label for="degerlendiren">Değerlendiren · Tarih</label><input type="text" id="degerlendiren" placeholder="Örn. A. Yılmaz · 13.07.2026"></div>

      <div class="field"><label for="veriyeri">Verinin işlendiği yer</label><select id="veriyeri"><option value="Yurt içi">Yurt içi</option><option value="Yurt dışı">Yurt dışı</option><option value="Karma">Karma</option><option value="Bilinmiyor">Bilinmiyor</option></select></div>
      <div class="field"><label for="dpa">Veri işleme sözleşmesi (DPA)</label><select id="dpa"><option value="Var (imzalı)">Var (imzalı)</option><option value="Görüşülüyor">Görüşülüyor</option><option value="Yok">Yok</option></select></div>

      <div class="field"><label>Güvenlik sertifikaları</label><div class="chk" id="sertifika">
        <label><input type="checkbox" value="ISO/IEC 27001">ISO 27001</label>
        <label><input type="checkbox" value="SOC 2">SOC 2</label>
        <label><input type="checkbox" value="ISO/IEC 42001">ISO 42001</label>
        <label><input type="checkbox" value="Belirtilmemiş / bilinmiyor">Yok / bilinmiyor</label>
      </div></div>

      <div class="field"><label for="durdurma">Acil durdurma / geri alma imkânı</label><select id="durdurma"><option value="Var">Var</option><option value="Kısıtlı">Kısıtlı</option><option value="Yok">Yok</option></select></div>
      <div class="field"><label for="bildirim">Olay / ihlal bildirim taahhüdü</label><select id="bildirim"><option value="Sözleşmede var">Sözleşmede var</option><option value="Sözlü / belirsiz">Sözlü / belirsiz</option><option value="Yok">Yok</option></select></div>
      <div class="field"><label for="altisleyen">Alt-işleyenler açıklanıyor mu?</label><select id="altisleyen"><option value="Evet">Evet</option><option value="Kısmen">Kısmen</option><option value="Hayır">Hayır</option></select></div>
      <div class="field"><label for="seffaflik">Model / çıktı şeffaflığı belgeleri</label><select id="seffaflik"><option value="Var">Var</option><option value="Kısmi">Kısmi</option><option value="Yok">Yok</option></select></div>

      <div class="field"><label for="notlar">Notlar / kırmızı bayraklar</label><textarea id="notlar" placeholder="Örn. veri saklama süresi belirsiz, alt-işleyen listesi eski…"></textarea></div>
    </form>

    <div class="tool-out">
      <div class="tool-out-head"><span class="t">Değerlendirme</span><div class="acts"><button type="button" class="tool-btn" id="copy">Kopyala</button><button type="button" class="tool-btn" id="dl" data-gate="tedarikci">İndir</button></div></div>
      <div class="tool-doc" id="out"></div>
    </div>
  </div>
  <p class="tool-note" style="max-width:820px">Tarayıcınızda çalışır; hiçbir bilgi sunucuya gönderilmez. Üretilen belge bir taslaktır ve hukuki tavsiye niteliği taşımaz. "Yurt dışı" veri yeri ve eksik DPA gibi işaretler, kurmadan önce çözülmesi gereken risklerdir.</p>
</div></section>
<section class="faq-sec"><div class="wrap">
  <h2 class="faq-h">Sıkça sorulan sorular</h2>
  <div class="faq-list">
    {faq.map((f) => (
      <details class="faq-item"><summary>{f.q}</summary><div class="faq-a">{f.a}</div></details>
    ))}
  </div>
</div></section>
</AppShell>

<script>
  const $ = (id) => document.getElementById(id);
  const checked = (id) => [...$(id).querySelectorAll('input:checked')].map(i => i.value);

  function flag(cond, warn){ return cond ? "  ⚠ " + warn + "\n" : ""; }

  function build(){
    const ted = ($('tedarikci').value || "[Tedarikçi / ürün adı]").trim();
    const deg = ($('degerlendiren').value || "[Değerlendiren · Tarih]").trim();
    const veriyeri = $('veriyeri').value;
    const dpa = $('dpa').value;
    const sert = checked('sertifika');
    const durdurma = $('durdurma').value;
    const bildirim = $('bildirim').value;
    const alt = $('altisleyen').value;
    const seffaf = $('seffaflik').value;
    const notlar = ($('notlar').value || "").trim();
    const sertStr = sert.length ? sert.join(", ") : "Belirtilmemiş";

    let t = "";
    t += "TEDARİKÇİ DEĞERLENDİRME (DUE DILIGENCE) — TASLAK\n";
    t += "Tedarikçi / ürün: " + ted + "\n";
    t += "Değerlendiren · Tarih: " + deg + "\n";
    t += "════════════════════════════════════\n\n";
    t += "1) VERİ VE AKTARIM\n";
    t += "  • Verinin işlendiği yer: " + veriyeri + "\n";
    t += flag(veriyeri === "Yurt dışı" || veriyeri === "Karma", "Yurt dışı aktarım: KVKK m.9 mekanizması (ör. standart sözleşme) ve aydınlatma satırı gerekir.");
    t += "  • Veri işleme sözleşmesi (DPA): " + dpa + "\n";
    t += flag(dpa !== "Var (imzalı)", "İmzalı DPA yok: sizin adınıza veri işleyen tedarikçiyle imzalanmalı; 'kullanım koşulları' yeterli değildir.");
    t += "\n2) GÜVENLİK\n";
    t += "  • Sertifikalar: " + sertStr + "\n";
    t += "  • Alt-işleyenler açıklanıyor mu: " + alt + "\n";
    t += flag(alt === "Hayır", "Alt-işleyenler açıklanmıyor: veri zincirinde görünürlük yok.");
    t += "\n3) KONTROL VE MÜDAHALE\n";
    t += "  • Acil durdurma / geri alma: " + durdurma + "\n";
    t += flag(durdurma === "Yok", "Durdurma yok: bir ajanı hızla durduramamak ciddi bir risktir.");
    t += "  • Olay / ihlal bildirim taahhüdü: " + bildirim + "\n";
    t += flag(bildirim !== "Sözleşmede var", "Yazılı bildirim taahhüdü yok: ihlali zamanında öğrenemeyebilirsiniz.");
    t += "\n4) ŞEFFAFLIK\n";
    t += "  • Model / çıktı şeffaflığı: " + seffaf + "\n\n";
    if (notlar) t += "NOTLAR / KIRMIZI BAYRAKLAR\n" + notlar + "\n\n";
    t += "SONUÇ\n";
    t += "  • Karar: [ ] Onayla   [ ] Şartlı onay   [ ] Reddet\n";
    t += "  • Şartlar / takip: ____________________________\n\n";
    t += "════════════════════════════════════\n";
    t += "Bu belge bir taslaktır ve hukuki tavsiye niteliği taşımaz.";
    return t;
  }

  function render(){ $('out').textContent = build(); }
  $('f').addEventListener('input', render);
  $('copy').addEventListener('click', async () => {
    try { await navigator.clipboard.writeText(build()); $('copy').textContent = "Kopyalandı ✓"; setTimeout(()=>$('copy').textContent="Kopyala",1500); } catch(e){}
  });
  $('dl').addEventListener('click', () => { window.AH.downloadWord("tedarikci-degerlendirme.doc", "Tedarikçi Değerlendirme", build()); });
  render();
</script>
</Base>
