---
import Base from "../../layouts/Base.astro";
import AppShell from "../../components/AppShell.astro";

const faq = [
  { q: "Görev tanımı neden yazılı olmalı?", a: "Yazılı olmayan bir görev tanımı denetlenemez ve zorlanamaz. Amaç, izinli ve yasaklı eylemler ile eskalasyon kurallarını yazıya dökmek, hem ekibin ortak anlayışını hem de bir olay anında hesap verebilirliği sağlar." },
  { q: "Yasaklı eylemleri yazmak yeterli mi?", a: "Hayır. Yasaklı eylemler yalnızca kâğıtta değil, mümkün olduğunca sistemde de (teknik limit, onaylı liste, kelime filtresi) uygulanmalıdır. Bu araç metni üretir; teknik uygulama sizin sorumluluğunuzdadır." },
  { q: "Girdiğim bilgiler bir yere gönderiliyor mu?", a: "Hayır. Araç tamamen tarayıcınızda çalışır; girdiğiniz hiçbir bilgi sunucuya gönderilmez veya saklanmaz." },
  { q: "Üretilen belge hukuki tavsiye midir?", a: "Hayır. Üretilen görev tanımı genel bilgilendirme amaçlı bir taslaktır ve hukuki tavsiye yerine geçmez; kendi durumunuza göre uyarlayın." },
];
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faq.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };
---
<Base title="Görev Tanımı Oluşturucu — Yapay Zeka Ajanı | Agent Hukuku" description="Her ajan için dört parçalı yazılı görev tanımı: amaç, izinli eylemler, yasaklı eylemler ve eskalasyon kuralları. Doldurun, Word olarak indirin. Tarayıcıda çalışır.">
<Fragment slot="head"><script type="application/ld+json" set:html={JSON.stringify(faqSchema)} /></Fragment>
<AppShell active="gorev" title="Görev Tanımı Oluşturucu">
<section class="page-hero"><div class="wrap">
  <div class="breadcrumb"><a href="/araclar">Araçlar</a> · Görev tanımı</div>
  <span class="kicker">Araç</span>
  <h1>Görev tanımı oluşturucu</h1>
  <p class="lead">Her ajanın dört parçalı, yazılı bir görev tanımı olmalı: amaç, izinli eylemler, yasaklı eylemler ve eskalasyon. Alanları doldurun, belge canlı oluşsun, Word olarak indirin.</p>
</div></section>

<section class="tex-showcase"><div class="wrap">
  <div class="tex-head"><span class="kicker">Sonuç böyle görünür</span><span class="tex-note">Örnek — alanlarınızı doldurdukça oluşur, Word olarak inersiniz.</span></div>
  <div class="card-ui tex" style="max-width:760px">
    <div class="mui-head"><div class="mui-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/><path d="M9 13h6M9 17h4"/></svg> Görev Tanımı</div><div class="mui-live">önizleme</div></div>
    <div class="tex-doc">
      <h4>Destek Yanıt Ajanı — Görev Tanımı</h4>
      <div class="dl">Sahibi: A. Yılmaz · Müşteri Hizmetleri</div>
      <div class="sec">1) Amaç</div>
      <p>Gelen destek e-postalarını sınıflar ve taslak yanıt üretir.</p>
      <div class="sec">2) İzinli eylemler</div>
      <p>Taslak yanıt oluşturmak · Bilgi tabanında arama yapmak</p>
      <div class="sec">3) Yasaklı eylemler</div>
      <p>Onaysız e-posta göndermek · İade/ödeme işlemi başlatmak</p>
      <div class="sec">4) Eskalasyon</div>
      <p>Şikâyet, hukuki tehdit veya 500 ₺ üstü talepte insana devreder.</p>
    </div>
  </div>
</div></section>

<section style="padding-top:6px"><div class="wrap">
  <div class="tool-grid">
    <form class="tool-form" id="f" autocomplete="off">
      <div class="field"><label for="ajan">Ajan adı</label><input type="text" id="ajan" placeholder="Örn. Destek Yanıt Ajanı"></div>
      <div class="field"><label for="sahip">Sahibi (isim · unvan)</label><input type="text" id="sahip" placeholder="Örn. A. Yılmaz · Müşteri Hizmetleri"></div>
      <div class="field"><label for="amac">Amaç ve kapsam</label><textarea id="amac" placeholder="Bu ajan ne için var, hangi süreçte, kimin için çalışır?"></textarea></div>
      <div class="field"><label for="izinli">İzinli eylemler <span class="hint" style="display:inline">(her satıra bir madde)</span></label><textarea id="izinli" placeholder="Taslak yanıt oluşturmak&#10;Bilgi tabanında arama yapmak"></textarea></div>
      <div class="field"><label for="yasak">Yasaklı eylemler <span class="hint" style="display:inline">(her satıra bir madde)</span></label><textarea id="yasak" placeholder="Onaysız e-posta göndermek&#10;İade/ödeme işlemi başlatmak"></textarea></div>
      <div class="field"><label for="eskalasyon">Eskalasyon — ne zaman insana devreder?</label><textarea id="eskalasyon" placeholder="Şikâyet, hukuki tehdit, belirsizlik ya da eşik üstü işlemde insana devret."></textarea></div>
      <div class="field"><label for="erisim">Eriştiği sistem / veri</label><input type="text" id="erisim" placeholder="Örn. Zendesk, bilgi tabanı, sipariş geçmişi"></div>
      <div class="field"><label for="onay">İnsan onayı eşiği</label><select id="onay"><option value="Eşik üstü işlemde">Eşik üstü işlemde</option><option value="Her dış işlemde">Her dış işlemde</option><option value="Yok">Yok</option></select></div>
    </form>

    <div class="tool-out">
      <div class="tool-out-head"><span class="t">Görev tanımı</span><div class="acts"><button type="button" class="tool-btn" id="copy">Kopyala</button><button type="button" class="tool-btn" id="dl" data-gate="gorev">İndir</button></div></div>
      <div class="tool-doc" id="out"></div>
    </div>
  </div>
  <p class="tool-note" style="max-width:820px">Tarayıcınızda çalışır; hiçbir bilgi sunucuya gönderilmez. Üretilen belge bir taslaktır ve hukuki tavsiye niteliği taşımaz. Yasaklı eylemleri kâğıtta bırakmayın — mümkün olduğunca sistemde de uygulayın.</p>
</div></section>
<section class="faq-sec"><div class="wrap">
  <h2 class="faq-h">Sıkça sorulan sorular</h2>
  <div class="faq-list">
    {faq.map((f) => (
      <details class="faq-item"><summary>{f.q}</summary><div class="faq-a">{f.a}</div></details>
    ))}
  </div>
</div></section>
</AppShell>

<script>
  const $ = (id) => document.getElementById(id);
  const lines = (id) => ($(id).value || "").split("\n").map(s => s.trim()).filter(Boolean);
  const bullets = (arr) => arr.length ? arr.map(x => "  • " + x).join("\n") : "  • —";

  function build(){
    const ajan = ($('ajan').value || "[Ajan adı]").trim();
    const sahip = ($('sahip').value || "[Sahibi]").trim();
    const amac = ($('amac').value || "[Ajanın amacı ve kapsamı]").trim();
    const izinli = lines('izinli');
    const yasak = lines('yasak');
    const esk = ($('eskalasyon').value || "[Eskalasyon kuralları]").trim();
    const erisim = ($('erisim').value || "—").trim();
    const onay = $('onay').value;

    let t = "";
    t += ajan.toUpperCase() + " — GÖREV TANIMI\n";
    t += "Sahibi: " + sahip + "\n";
    t += "════════════════════════════════════\n\n";
    t += "1) AMAÇ VE KAPSAM\n" + amac + "\n\n";
    t += "2) İZİNLİ EYLEMLER\n" + bullets(izinli) + "\n\n";
    t += "3) YASAKLI EYLEMLER\n" + bullets(yasak) + "\n";
    t += "  (Bu eylemler mümkün olduğunca sistemde de engellenmelidir.)\n\n";
    t += "4) ESKALASYON KURALLARI\n" + esk + "\n\n";
    t += "EK BİLGİLER\n";
    t += "  • Eriştiği sistem/veri: " + erisim + "\n";
    t += "  • İnsan onayı: " + onay + "\n\n";
    t += "════════════════════════════════════\n";
    t += "Bu belge bir taslaktır ve hukuki tavsiye niteliği taşımaz.";
    return t;
  }

  function render(){ $('out').textContent = build(); }
  $('f').addEventListener('input', render);
  $('copy').addEventListener('click', async () => {
    try { await navigator.clipboard.writeText(build()); $('copy').textContent = "Kopyalandı ✓"; setTimeout(()=>$('copy').textContent="Kopyala",1500); } catch(e){}
  });
  $('dl').addEventListener('click', () => { window.AH.downloadWord("gorev-tanimi.doc", "Görev Tanımı", build()); });
  render();
</script>
</Base>
