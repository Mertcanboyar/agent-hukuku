---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<Base title="İletişim — Agent Hukuku" description="Agent Hukuku ile iletişime geçin: sorularınız, iş birlikleri, konuşma ve eğitim talepleri için bize yazın.">
<Header />
<main>
<section class="page-hero"><div class="wrap">
  <div class="breadcrumb"><a href="/">Ana sayfa</a> · İletişim</div>
  <span class="kicker">İletişim</span>
  <h1>Bize ulaşın</h1>
  <p class="lead">Soru, geri bildirim, iş birliği ya da konuşma/eğitim talebi — hepsine açığız. Aşağıdaki formu doldurun veya doğrudan e-posta gönderin.</p>
</div></section>

<section class="il-sec"><div class="wrap">
  <div class="il-grid">
    <div class="il-info">
      <div class="il-item">
        <span class="il-lab">E-posta</span>
        <a class="il-big" href="mailto:merhaba@agenthukuku.com">merhaba@agenthukuku.com</a>
        <p>Genel sorular, iş birlikleri ve talepler için doğrudan yazabilirsiniz.</p>
      </div>
      <div class="il-item">
        <span class="il-lab">Kurucu</span>
        <div class="il-big">Mert Can Boyar</div>
        <p class="il-links"><a href="https://mertcanboyar.com" target="_blank" rel="noopener">mertcanboyar.com ↗</a> · <a href="https://www.linkedin.com/in/mertcanboyar/" target="_blank" rel="noopener">LinkedIn ↗</a></p>
      </div>
      <div class="il-item">
        <span class="il-lab">Ne için yazabilirsiniz?</span>
        <ul class="il-ul"><li>Ajan yönetişimi ve KVKK sorularınız</li><li>Konuşma, atölye ve eğitim davetleri</li><li>İçerik iş birlikleri ve geri bildirim</li><li>Bir vaka önerisi ya da düzeltme</li></ul>
      </div>
    </div>

    <div class="il-form-card">
      <h2>Mesaj gönderin</h2>
      <form id="ilForm" novalidate>
        <div class="il-f"><label for="ilName">Ad Soyad</label><input type="text" id="ilName" placeholder="Adınız"></div>
        <div class="il-f"><label for="ilEmail">E-posta</label><input type="email" id="ilEmail" placeholder="ornek@sirket.com" required></div>
        <div class="il-f"><label for="ilMsg">Mesajınız</label><textarea id="ilMsg" rows="5" placeholder="Nasıl yardımcı olabiliriz?" required></textarea></div>
        <label class="consent"><input type="checkbox" id="ilConsent" class="cbox" required><span>İletişim talebimin yanıtlanması amacıyla e-postamın ve mesajımın işlenmesine <a href="/aydinlatma" target="_blank">Aydınlatma Metni</a> uyarınca onay veriyorum.</span></label>
        <button type="submit" class="btn btn-primary" id="ilSubmit">Gönder</button>
        <p class="il-msg" id="ilThanks" hidden></p>
      </form>
    </div>
  </div>
</div></section>
</main>
<Footer />

<script is:inline>
(function () {
  var f = document.getElementById("ilForm");
  var em = document.getElementById("ilEmail"), msg = document.getElementById("ilMsg");
  var nm = document.getElementById("ilName"), cs = document.getElementById("ilConsent");
  var btn = document.getElementById("ilSubmit"), thanks = document.getElementById("ilThanks");
  f.addEventListener("submit", function (e) {
    e.preventDefault();
    var email = (em.value || "").trim();
    if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) { em.focus(); return; }
    if (!(msg.value || "").trim()) { msg.focus(); return; }
    if (!cs.checked) { cs.focus(); return; }
    var old = btn.textContent; btn.disabled = true; btn.textContent = "Gönderiliyor…";
    fetch("/api/lead", {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email: email, type: "iletisim", message: msg.value.trim(), meta: { name: (nm.value || "").trim() }, consent: true })
    }).then(function (r) { return r.json(); }).then(function (d) {
      if (d && d.ok) {
        f.querySelectorAll(".il-f, .consent, #ilSubmit").forEach(function (el) { el.style.display = "none"; });
        thanks.hidden = false; thanks.textContent = "Teşekkürler! Mesajınızı aldık, en kısa sürede dönüş yapacağız.";
      } else {
        btn.disabled = false; btn.textContent = old;
        alert((d && d.error) || "Gönderilemedi. Lütfen doğrudan merhaba@agenthukuku.com adresine yazın.");
      }
    }).catch(function () {
      btn.disabled = false; btn.textContent = old;
      alert("Bağlantı hatası. Lütfen doğrudan merhaba@agenthukuku.com adresine yazın.");
    });
  });
})();
</script>

<style>
  .il-sec{padding-top:6px}
  .il-grid{display:grid;grid-template-columns:1fr 1.1fr;gap:32px;align-items:start}
  .il-info{display:flex;flex-direction:column;gap:22px}
  .il-item .il-lab{font:700 .7rem var(--sans);letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
  .il-big{display:block;font-family:var(--serif);font-size:1.35rem;color:var(--ink);margin:5px 0 6px;text-decoration:none}
  a.il-big:hover{color:var(--accent)}
  .il-item p{color:var(--slate);font-size:.94rem;margin:0;line-height:1.55}
  .il-links a{color:var(--accent);text-decoration:none}
  .il-ul{margin:6px 0 0;padding-left:1.1em;color:var(--slate);font-size:.94rem;line-height:1.7}
  .il-form-card{background:var(--card);border:1px solid var(--line);border-radius:18px;box-shadow:var(--sh-sm);padding:26px 26px 24px}
  .il-form-card h2{font-family:var(--serif);font-size:1.3rem;color:var(--ink);margin:0 0 16px}
  .il-f{margin-bottom:14px}
  .il-f label{display:block;font:600 .8rem var(--sans);color:var(--ink-2);margin-bottom:5px}
  .il-f input,.il-f textarea{width:100%;font:400 .95rem var(--sans);color:var(--ink);background:var(--bg);border:1px solid var(--line);border-radius:9px;padding:11px 12px;resize:vertical}
  .il-f input:focus,.il-f textarea:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px color-mix(in srgb,var(--accent) 15%,transparent)}
  .il-form-card .consent{display:flex;gap:9px;font-size:.82rem;color:var(--slate);line-height:1.45;margin:4px 0 16px}
  .il-form-card .consent a{color:var(--accent)}
  .il-form-card .btn{width:100%}
  .il-msg{margin:0;font-size:.95rem;font-weight:600;color:#2E7D5B;text-align:center}
  @media(max-width:820px){.il-grid{grid-template-columns:1fr}}
</style>
</Base>
