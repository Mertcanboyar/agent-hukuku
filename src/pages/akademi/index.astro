---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const modules = [
  {
    n: "01", lvl: "Seviye 1 · Temel", t: "Temeller",
    d: "Ajan nedir, neden farklıdır ve sorumluluk kimdedir? Her şeyin üzerine kurulduğu zemin.",
    lessons: [
      { id: "1.1", t: "Ajan nedir? Chatbot'tan ajana", meta: "Slaytlı · ~8 dk", url: "/akademi/ajan-nedir" },
      { id: "1.2", t: "Veri sorumlusu sizsiniz", meta: "Slaytlı · ~7 dk", url: "/akademi/veri-sorumlusu" },
      { id: "1.3", t: "Beş ilke: yönetişimin omurgası", meta: "Slaytlı · ~8 dk", url: "/akademi/bes-ilke" },
    ],
  },
  {
    n: "02", lvl: "Seviye 2 · Kurulum", t: "Ajanı Güvenli Kurmak",
    d: "Envanterden acil durdurmaya: bir ajanı denetlenebilir ve güvenli biçimde sahaya almanın pratiği.",
    lessons: [
      { id: "2.1", t: "Ajan envanteri: elinizde ne var?", meta: "Slaytlı · ~7 dk", url: "/akademi/ajan-envanteri" },
      { id: "2.2", t: "Görev tanımı ve sınırlar", meta: "Slaytlı · ~8 dk", url: "/akademi/gorev-tanimi" },
      { id: "2.3", t: "Kimlik ve erişim: en az yetki", meta: "Slaytlı · ~7 dk", url: "/akademi/kimlik-erisim" },
      { id: "2.4", t: "Döngüde insan: onay eşikleri", meta: "Slaytlı · ~8 dk", url: "/akademi/insan-onayi" },
      { id: "2.5", t: "Acil durdurma ve emekliye ayırma", meta: "Slaytlı · ~8 dk", url: "/akademi/acil-durdurma" },
    ],
  },
  {
    n: "03", lvl: "Seviye 3 · Uyum", t: "KVKK & Uyum",
    d: "İşleme şartından yurt dışı aktarıma: ajanları KVKK'ya uyumlu yürütmenin hukuki çatısı.",
    lessons: [
      { id: "3.1", t: "KVKK'yı bir derste anlamak (ajan gözlüğüyle)" },
      { id: "3.2", t: "Aydınlatma: ajan kullandığınızı söylemek" },
      { id: "3.3", t: "Yurt dışına veri aktarımı" },
      { id: "3.4", t: "VERBİS, sözleşmeler ve standartlar" },
      { id: "3.5", t: "Kurumun YZ rehberleri ne bekliyor?" },
    ],
  },
  {
    n: "04", lvl: "Seviye 4 · İleri", t: "İleri Konular",
    d: "İzlemeden çalışma zamanı korkuluklarına ve çok-ajanlı sistemlere: olgun yönetişimin ileri katmanı.",
    lessons: [
      { id: "4.1", t: "Kayıt ve denetim izi" },
      { id: "4.2", t: "İzleme ve sapma (drift)" },
      { id: "4.3", t: "Saldırılar ve savunmalar" },
      { id: "4.4", t: "Runtime guardrails & policy-as-code" },
      { id: "4.5", t: "Çok-ajanlı sistemler & EU AI Act / ISO 42001" },
    ],
  },
];
const total = modules.reduce((a, m) => a + m.lessons.length, 0);
---
<Base title="Akademi — Ajan Hukuku ve Yönetişimi Öğrenme Yolu | Agent Hukuku" description="Temellerden ileri konulara: yapay zeka ajanlarının hukuku ve yönetişimini adım adım öğrenin. Slaytlı, ücretsiz dersler.">
<Header />
<main>
<section class="page-hero"><div class="wrap">
  <div class="breadcrumb"><a href="/">Ana sayfa</a> · Akademi</div>
  <span class="kicker">Akademi</span>
  <h1>Ajan hukukunu ve yönetişimini<br>adım adım öğrenin</h1>
  <p class="lead">Temellerden ileri konulara uzanan bir öğrenme yolu. Her ders, kitaptaki içeriği slaytlarla ve sade bir anlatımla veriyor — hukukçu ya da yazılımcı olmanız gerekmez.</p>
  <div class="aca-meta">
    <span><b>4</b> seviye</span><span><b>{total}</b> ders</span><span><b>Ücretsiz</b> ve açık</span>
  </div>
  <div class="aca-phase">📼 <b>Yakında:</b> her derse video anlatımlar da eklenecek (Faz 2).</div>
</div></section>

<section class="path-sec"><div class="wrap">
  {modules.map((m) => (
    <div class="mod reveal">
      <div class="mod-head"><div class="mod-n">{m.n}</div><div><span class="mod-lvl">{m.lvl}</span><h2>{m.t}</h2><p>{m.d}</p></div></div>
      <ol class="lessons">
        {m.lessons.map((l) => (
          l.url ? (
            <li class="lesson ready"><a href={l.url}><span class="ln">{l.id}</span><span class="lt">{l.t}</span><span class="lmeta">{l.meta}</span><span class="lgo">→</span></a></li>
          ) : (
            <li class="lesson soon"><span class="ln">{l.id}</span><span class="lt">{l.t}</span><span class="badge">Yakında</span></li>
          )
        ))}
      </ol>
    </div>
  ))}
</div></section>

<section class="about-cta"><div class="wrap"><div class="cta reveal">
  <span class="kicker" style="color:#7fb6e0">Başlayın</span>
  <h2>İlk dersle başlayın</h2>
  <p>“Ajan nedir?” dersi, chatbot ile ajanı ayıran o kritik farkla açıyor — bu alandaki en pahalı ilk hatayı önlemek için.</p>
  <div class="hero-cta" style="justify-content:center"><a class="btn btn-primary" href="/akademi/ajan-nedir">İlk derse başla →</a><a class="btn btn-ghost" href="/kitap">Kitabı indir</a></div>
</div></div></section>
</main>
<Footer />

<script>
document.documentElement.classList.add('js');
window.addEventListener('DOMContentLoaded',function(){
  var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.12});
  document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
});
</script>

<style>
  .aca-meta{display:flex;gap:22px;margin-top:20px;flex-wrap:wrap}
  .aca-meta span{font-size:.95rem;color:var(--muted)}
  .aca-meta b{color:var(--ink);font-family:var(--serif);font-size:1.15rem;margin-right:4px}
  .aca-phase{margin-top:18px;display:inline-block;background:var(--bg-2);border:1px solid var(--line);border-radius:12px;padding:10px 16px;font-size:.92rem;color:var(--ink-2)}
  .path-sec{padding-top:6px}
  .mod{background:var(--card);border:1px solid var(--line);border-radius:20px;box-shadow:var(--sh-sm);padding:26px 26px 12px;margin-bottom:22px}
  .mod-head{display:flex;gap:18px;align-items:flex-start;margin-bottom:18px}
  .mod-n{flex:0 0 auto;width:56px;height:56px;border-radius:15px;background:var(--grad);color:#fff;display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-weight:700;font-size:1.4rem;box-shadow:var(--sh-sm)}
  .mod-lvl{font:700 11px var(--sans);letter-spacing:.06em;text-transform:uppercase;color:var(--accent)}
  .mod-head h2{font-family:var(--serif);font-size:1.4rem;color:var(--ink);margin:3px 0 5px}
  .mod-head p{color:var(--slate);margin:0;line-height:1.55;max-width:640px}
  .lessons{list-style:none;margin:0;padding:0}
  .lesson{border-top:1px solid var(--line)}
  .lesson a{display:flex;align-items:center;gap:14px;padding:14px 4px;text-decoration:none;color:var(--ink);transition:background .12s,padding .12s;border-radius:10px}
  .lesson.ready a:hover{background:var(--bg-2);padding-left:12px;padding-right:12px}
  .lesson.soon{display:flex;align-items:center;gap:14px;padding:14px 4px;color:var(--muted)}
  .ln{flex:0 0 auto;font:700 13px var(--sans);color:var(--accent);width:34px}
  .lesson.soon .ln{color:var(--line-2)}
  .lt{flex:1;font-weight:600}
  .lmeta{font-size:.85rem;color:var(--muted)}
  .lgo{color:var(--accent);font-size:1.1rem}
  .badge{font:600 11px var(--sans);letter-spacing:.04em;text-transform:uppercase;color:var(--muted);border:1px solid var(--line);border-radius:20px;padding:3px 10px}
  .about-cta{margin-top:8px}
</style>
</Base>
