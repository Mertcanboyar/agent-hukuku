---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
const {
  title = "Agent Hukuku — Yapay zeka ajanları için hukuk ve yönetişim",
  description = "Türkiye'de yapay zeka ajanlarının hukuku ve yönetişimi. KVKK uyumu, vaka temelli rehberler, şablonlar ve olgunluk testi.",
  image = "/og/agent-hukuku-og.png",
  type = "website",
} = Astro.props;

const site = Astro.site ?? new URL("https://agenthukuku.com");
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;

// --- Otomatik BreadcrumbList (tüm sayfalar) ---
const segs = Astro.url.pathname.split("/").filter(Boolean);
const crumbMap = {
  akademi: "Akademi", makaleler: "Makaleler", vakalar: "Vakalar", radar: "Mevzuat Radarı",
  araclar: "Araçlar", degerlendirme: "Değerlendirme", sablonlar: "Şablonlar", kitap: "Kitap",
  hakkinda: "Hakkında", aydinlatma: "Aydınlatma Metni", iletisim: "İletişim", api: "API",
  "aydinlatma-olusturucu": "Aydınlatma oluşturucu", "isleme-sarti-secici": "İşleme şartı seçici",
  "vked-taslagi": "VKED taslağı", "agent-politikasi": "Ajan politikası",
};
const leafName = title.split("|")[0].trim();
const breadcrumbSchema = segs.length ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana sayfa", item: `${site.origin}/` },
    ...segs.map((s, i) => ({
      "@type": "ListItem",
      position: i + 2,
      name: crumbMap[s] || (i === segs.length - 1 ? leafName : decodeURIComponent(s)),
      item: new URL("/" + segs.slice(0, i + 1).join("/"), site).href,
    })),
  ],
} : null;

// --- Akademi dersleri için otomatik LearningResource (Course'a bağlı) ---
const isLesson = segs[0] === "akademi" && segs.length === 2;
const lessonSchema = isLesson ? {
  "@context": "https://schema.org",
  "@type": "LearningResource",
  name: leafName,
  description,
  url: canonical,
  inLanguage: "tr-TR",
  learningResourceType: "Slaytlı ders",
  isAccessibleForFree: true,
  isPartOf: { "@type": "Course", "@id": `${site.origin}/akademi#course`, name: "Ajan Hukuku ve Yönetişimi Akademisi", url: `${site.origin}/akademi` },
  provider: { "@id": `${site.origin}/#org` },
  author: { "@type": "Person", name: "Mert Can Boyar", url: "https://mertcanboyar.com" },
  publisher: { "@id": `${site.origin}/#org` },
} : null;

const orgSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site.origin}/#org`,
      name: "Agent Hukuku",
      url: site.origin,
      logo: `${site.origin}/og/agent-hukuku-og.png`,
      description: "Yapay zeka ajanları için hukuk ve yönetişim. KVKK uyumu, vaka temelli rehberler ve şablonlar.",
      founder: { "@type": "Person", name: "Mert Can Boyar", url: "https://mertcanboyar.com" },
      sameAs: ["https://mertcanboyar.com"],
    },
    {
      "@type": "WebSite",
      "@id": `${site.origin}/#website`,
      url: site.origin,
      name: "Agent Hukuku",
      inLanguage: "tr-TR",
      publisher: { "@id": `${site.origin}/#org` },
    },
  ],
};
---
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Mert Can Boyar" />
  <meta name="theme-color" content="#1B2A41" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <meta property="og:type" content={type} />
  <meta property="og:site_name" content="Agent Hukuku" />
  <meta property="og:locale" content="tr_TR" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Lora:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  {lessonSchema && <script type="application/ld+json" set:html={JSON.stringify(lessonSchema)} />}
  <slot name="head" />
  <Analytics />
</head>
<body>
  <slot />
  <script is:inline>
  document.addEventListener('submit', async function(e){
    var f = e.target.closest && e.target.closest('form[data-lead]');
    if(!f) return;
    e.preventDefault();
    var input = f.querySelector('input[type=email]');
    var email = input && input.value;
    var type = f.getAttribute('data-lead');
    var box = f.querySelector('input.cbox');
    if(box && !box.checked){ box.focus(); alert('Devam etmek için KVKK Aydınlatma Metni kapsamında açık rıza vermeniz gerekir.'); return; }
    var btn = f.querySelector('button[type=submit]');
    var old = btn ? btn.textContent : '';
    if(btn){ btn.disabled = true; btn.textContent = 'Gönderiliyor…'; }
    try {
      var meta = (window.__leadMeta ? window.__leadMeta() : undefined);
      var r = await fetch('/api/lead', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ email: email, type: type, meta: meta, consent: box ? box.checked : true }) });
      var d = await r.json();
      if(d && d.ok){ f.innerHTML = '<p style="color:#2f6b60;font-weight:600;margin:0">Teşekkürler! E-postanıza gönderdik.</p>'; }
      else { if(btn){ btn.disabled=false; btn.textContent=old; } alert((d && d.error) || 'Bir hata oluştu.'); }
    } catch(err){ if(btn){ btn.disabled=false; btn.textContent=old; } alert('Bağlantı hatası, tekrar deneyin.'); }
  });
  </script>
</body>
</html>
